# Artefacts de build
build/

# Cache de byte-code Python (outils dans tools/)
__pycache__/

# Log transitoire de construction du cross-compiler (toolchain/build-i686-elf.sh)
build-toolchain.log

# Réglages locaux Claude Code (conservés hors versionnement et hors distclean)
.claude/settings.local.json

# Sources/outils du toolchain (construits localement, hors repo)
*.o
*.bin
*.img
*.iso

# Exception : la police VGA 8x16 est un asset SOURCE (référence, pas un artefact) → versionnée
!assets/fonts/*.bin
